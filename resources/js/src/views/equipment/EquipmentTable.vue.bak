<template>
  <div class="equipment-table">
    <DataTable
      :columns="columns"
      :server-side="true"
      :url="'/api/equipment/data'"
      :actions="actions"
      :filters="filters"
      @edit="handleEdit"
      @delete="handleDelete"
      @create="handleCreate"
      @view="handleView"
    >
      <!-- Custom Column Templates -->
      <template #equipment_code="{ row }">
        <span class="font-mono text-sm">{{ row.equipment_code }}</span>
      </template>

      <template #category="{ row }">
        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium">
          {{ row.category }}
        </span>
      </template>

      <template #condition="{ row }">
        <span 
          :class="getConditionClass(row.condition)"
          class="px-2 py-1 rounded-full text-xs font-medium"
        >
          {{ row.condition }}
        </span>
      </template>

      <template #status="{ row }">
        <span 
          :class="getStatusClass(row.status)"
          class="px-2 py-1 rounded-full text-xs font-medium"
        >
          {{ formatStatus(row.status) }}
        </span>
      </template>

      <template #purchase_price="{ row }">
        <span class="font-medium">{{ row.purchase_price || 'N/A' }}</span>
      </template>

      <template #age_in_years="{ row }">
        <span>{{ row.age_in_years }}</span>
      </template>

      <template #last_maintenance_date="{ row }">
        <span>{{ formatDate(row.last_maintenance_date) }}</span>
      </template>

      <template #next_maintenance_date="{ row }">
        <span 
          :class="getMaintenanceDateClass(row.next_maintenance_date)"
          class="font-medium"
        >
          {{ formatDate(row.next_maintenance_date) }}
        </span>
      </template>

      <template #notes="{ row }">
        <div class="max-w-xs truncate" :title="row.notes">
          {{ row.notes || 'No notes' }}
        </div>
      </template>

      <template #created_at="{ row }">
        <span>{{ row.created_at }}</span>
      </template>
    </DataTable>
  </div>
</template>

<script setup>
import { ref } from 'vue';
import DataTable from '@/views/components/DataTable/index.vue';

// Meta information
defineOptions({
  name: 'EquipmentTable'
});

// Table columns configuration
const columns = ref([
  {
    data: 'name',
    title: 'Equipment Name',
    searchable: true,
    sortable: true
  },
  {
    data: 'equipment_code',
    title: 'Equipment Code',
    searchable: true,
    sortable: true
  },
  {
    data: 'category',
    title: 'Category',
    searchable: true,
    sortable: true
  },
  {
    data: 'purchase_price',
    title: 'Purchase Price',
    searchable: false,
    sortable: true
  },
  {
    data: 'age_in_years',
    title: 'Age (Years)',
    searchable: false,
    sortable: false
  },
  {
    data: 'condition',
    title: 'Condition',
    searchable: true,
    sortable: true
  },
  {
    data: 'last_maintenance_date',
    title: 'Last Maintenance',
    searchable: false,
    sortable: true
  },
  {
    data: 'next_maintenance_date',
    title: 'Next Maintenance',
    searchable: false,
    sortable: true
  },
  {
    data: 'status',
    title: 'Status',
    searchable: true,
    sortable: true
  },
  {
    data: 'notes',
    title: 'Notes',
    searchable: true,
    sortable: false
  },
  {
    data: 'created_at',
    title: 'Created At',
    searchable: false,
    sortable: true
  }
]);

// Table actions configuration
const actions = ref({
  create: true,
  view: true,
  edit: true,
  delete: true
});

// Filters configuration
const filters = ref([
  {
    name: 'category',
    type: 'select',
    placeholder: 'Filter by Category',
    options: [
      { value: '', text: 'All Categories' },
      { value: 'cardio', text: 'Cardio' },
      { value: 'strength', text: 'Strength' },
      { value: 'free_weights', text: 'Free Weights' },
      { value: 'accessories', text: 'Accessories' },
      { value: 'machines', text: 'Machines' }
    ]
  },
  {
    name: 'condition',
    type: 'select',
    placeholder: 'Filter by Condition',
    options: [
      { value: '', text: 'All Conditions' },
      { value: 'excellent', text: 'Excellent' },
      { value: 'good', text: 'Good' },
      { value: 'fair', text: 'Fair' },
      { value: 'poor', text: 'Poor' },
      { value: 'broken', text: 'Broken' }
    ]
  },
  {
    name: 'status',
    type: 'select',
    placeholder: 'Filter by Status',
    options: [
      { value: '', text: 'All Statuses' },
      { value: 'active', text: 'Active' },
      { value: 'under_maintenance', text: 'Under Maintenance' },
      { value: 'retired', text: 'Retired' }
    ]
  }
]);

// Helper methods
const getConditionClass = (condition) => {
  const conditionClasses = {
    'excellent': 'bg-green-100 text-green-800',
    'good': 'bg-blue-100 text-blue-800',
    'fair': 'bg-yellow-100 text-yellow-800',
    'poor': 'bg-orange-100 text-orange-800',
    'broken': 'bg-red-100 text-red-800'
  };
  return conditionClasses[condition] || 'bg-gray-100 text-gray-800';
};

const getStatusClass = (status) => {
  const statusClasses = {
    'active': 'bg-green-100 text-green-800',
    'under_maintenance': 'bg-yellow-100 text-yellow-800',
    'retired': 'bg-red-100 text-red-800'
  };
  return statusClasses[status] || 'bg-gray-100 text-gray-800';
};

const getMaintenanceDateClass = (date) => {
  if (!date) return 'text-gray-500';
  const maintenanceDate = new Date(date);
  const now = new Date();
  const diffInDays = Math.ceil((maintenanceDate - now) / (1000 * 60 * 60 * 24));
  
  if (diffInDays < 0) return 'text-red-600'; // Overdue
  if (diffInDays <= 7) return 'text-orange-600'; // Due soon
  return 'text-gray-800'; // Normal
};

const formatStatus = (status) => {
  return status.split('_').map(word => 
    word.charAt(0).toUpperCase() + word.slice(1)
  ).join(' ');
};

const formatDate = (date) => {
  if (!date) return 'N/A';
  return new Date(date).toLocaleDateString();
};

// Action handlers
const handleCreate = () => {
  // TODO: Implement create equipment functionality
  console.log('Create equipment');
};

const handleEdit = (equipment) => {
  // TODO: Implement edit equipment functionality
  console.log('Edit equipment:', equipment);
};

const handleDelete = (equipment) => {
  // TODO: Implement delete equipment functionality
  console.log('Delete equipment:', equipment);
};

const handleView = (equipment) => {
  // TODO: Implement view equipment functionality
  console.log('View equipment:', equipment);
};
</script>


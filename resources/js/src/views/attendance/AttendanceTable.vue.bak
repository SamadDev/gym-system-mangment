// Helper methods
const getEntryMethodClass = (method) => {
  const methodClasses = {
    'manual': 'bg-blue-100 text-blue-800',
    'card': 'bg-green-100 text-green-800',
    'qr': 'bg-purple-100 text-purple-800'
  };
  return methodClasses[method] || 'bg-gray-100 text-gray-800';
};

const getDurationClass = (duration) => {
  if (!duration || duration === 'In progress') {
    return 'text-orange-600';
  }
  return 'text-gray-800';
};

const formatEntryMethod = (method) => {
  const methods = {
    'manual': 'Manual',
    'card': 'Card',
    'qr': 'QR Code'
  };
  return methods[method] || method;
};

const formatDateTime = (dateTime) => {
  if (!dateTime) return 'N/A';
  return new Date(dateTime).toLocaleDateString();
};

const formatTime = (dateTime) => {
  if (!dateTime) return 'N/A';
  return new Date(dateTime).toLocaleTimeString('en-US', { 
    hour: '2-digit', 
    minute: '2-digit',
    hour12: true
  });
};

const formatDate = (date) => {
  if (!date) return 'N/A';
  return new Date(date).toLocaleDateString();
};

